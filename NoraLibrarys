        -------------------------------------------------------------------
        -- Tab:Toggle
        -------------------------------------------------------------------
        function Tab:Toggle(cfg3)
            cfg3 = cfg3 or {}
            local state = cfg3.Default or false
            local card  = newCard(44)

            -- Name
            mk("TextLabel", {
                Size             = UDim2.new(1, -64, 0, 20),
                Position         = UDim2.fromOffset(14, 8),
                BackgroundTransparency = 1,
                Text             = cfg3.Name or "Toggle",
                TextColor3       = T.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = card,
            })
            -- Optional description
            if cfg3.Desc then
                mk("TextLabel", {
                    Size             = UDim2.new(1, -64, 0, 14),
                    Position         = UDim2.fromOffset(14, 26),
                    BackgroundTransparency = 1,
                    Text             = cfg3.Desc,
                    TextColor3       = T.TextMuted,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 10,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    Parent           = card,
                })
            end

            -- Pill switch
            local pill = mk("Frame", {
                Size             = UDim2.fromOffset(38, 21),
                Position         = UDim2.new(1, -50, 0.5, -10),
                BackgroundColor3 = state and T.Accent or T.CardActive,
                BorderSizePixel  = 0,
                Parent           = card,
            })
            corner(pill, 11)
            stroke(pill, state and T.AccentDim or T.BorderLight, 1)

            local knob = mk("Frame", {
                Size             = UDim2.fromOffset(15, 15),
                Position         = state and UDim2.fromOffset(20, 3) or UDim2.fromOffset(3, 3),
                BackgroundColor3 = Color3.new(1,1,1),
                BorderSizePixel  = 0,
                Parent           = pill,
            })
            corner(knob, 8)

            local function setToggle(v)
                state = v
                tween(pill,  {BackgroundColor3 = v and T.Accent or T.CardActive}, 0.15)
                tween(knob,  {Position = v and UDim2.fromOffset(20,3) or UDim2.fromOffset(3,3)}, 0.15)
                if cfg3.Callback then cfg3.Callback(v) end
            end

            local hit = mk("TextButton", {
                Size             = UDim2.fromScale(1,1),
                BackgroundTransparency = 1,
                Text             = "",
                Parent           = card,
            })
            hit.Activated:Connect(function() setToggle(not state) end)
            hit.MouseEnter:Connect(function() tween(card, {BackgroundColor3=T.CardHover}, 0.12) end)
            hit.MouseLeave:Connect(function() tween(card, {BackgroundColor3=T.Card}, 0.12) end)

            return { Set = setToggle, Get = function() return state end }
        end

        -------------------------------------------------------------------
        -- Tab:Slider
        -------------------------------------------------------------------
        function Tab:Slider(cfg3)
            cfg3 = cfg3 or {}
            local min  = cfg3.Min      or 0
            local max  = cfg3.Max      or 100
            local val  = cfg3.Default  or min
            local prec = cfg3.Precision or 0

            local card = newCard(58)
            pad(card, 10, 14, 10, 14)

            -- Top row: name + value
            mk("TextLabel", {
                Size             = UDim2.new(0.6, 0, 0, 18),
                BackgroundTransparency = 1,
                Text             = cfg3.Name or "Slider",
                TextColor3       = T.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = card,
            })
            local valLbl = mk("TextLabel", {
                Size             = UDim2.new(0.4, 0, 0, 18),
                Position         = UDim2.fromScale(0.6, 0),
                BackgroundTransparency = 1,
                Text             = tostring(val),
                TextColor3       = T.Accent,
                Font             = Enum.Font.GothamBold,
                TextSize         = 12,
                TextXAlignment   = Enum.TextXAlignment.Right,
                Parent           = card,
            })

            -- Track
            local track = mk("Frame", {
                Size             = UDim2.new(1, 0, 0, 5),
                Position         = UDim2.new(0, 0, 0, 30),
                BackgroundColor3 = T.CardActive,
                BorderSizePixel  = 0,
                Parent           = card,
            })
            corner(track, 3)

            local fillR = (val - min) / (max - min)
            local fill  = mk("Frame", {
                Size             = UDim2.new(fillR, 0, 1, 0),
                BackgroundColor3 = T.Accent,
                BorderSizePixel  = 0,
                Parent           = track,
            })
            corner(fill, 3)

            local knob = mk("Frame", {
                Size             = UDim2.fromOffset(15, 15),
                Position         = UDim2.new(fillR, -7, 0.5, -7),
                BackgroundColor3 = Color3.new(1,1,1),
                BorderSizePixel  = 0,
                ZIndex           = 2,
                Parent           = track,
            })
            corner(knob, 8)
            -- Knob accent ring
            mk("UIStroke", {
                Color     = T.Accent,
                Thickness = 2,
                Parent    = knob,
            })

            local dragging = false
            local function update(x)
                local r = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                local v = math.round((min + (max - min) * r) * 10^prec) / 10^prec
                val = v
                valLbl.Text = tostring(v)
                tween(fill, {Size = UDim2.new(r, 0, 1, 0)}, 0.05)
                tween(knob, {Position = UDim2.new(r, -7, 0.5, -7)}, 0.05)
                if cfg3.Callback then cfg3.Callback(v) end
            end

            local hit = mk("TextButton", {
                Size             = UDim2.new(1, 0, 0, 24),
                Position         = UDim2.new(0, 0, 0, 22),
                BackgroundTransparency = 1,
                Text             = "",
                ZIndex           = 3,
                Parent           = card,
            })
            hit.MouseButton1Down:Connect(function() dragging=true; update(Mouse.X) end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(Mouse.X) end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging=false end
            end)

            return { Get = function() return val end }
        end

        -------------------------------------------------------------------
        -- Tab:Dropdown
        -------------------------------------------------------------------
        function Tab:Dropdown(cfg3)
            cfg3 = cfg3 or {}
            local options  = cfg3.Options or {}
            local selected = cfg3.Default or (options[1] or "")

            local card = newCard(38)
            card.ClipsDescendants = false
            card.ZIndex = 10

            mk("TextLabel", {
                Size             = UDim2.new(0.55, 0, 1, 0),
                Position         = UDim2.fromOffset(14, 0),
                BackgroundTransparency = 1,
                Text             = cfg3.Name or "Dropdown",
                TextColor3       = T.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = card,
            })

            -- Current value button
            local selBtn = mk("TextButton", {
                Size             = UDim2.fromOffset(108, 26),
                Position         = UDim2.new(1, -120, 0.5, -13),
                BackgroundColor3 = T.CardActive,
                Text             = selected,
                TextColor3       = T.Accent,
                Font             = Enum.Font.GothamSemibold,
                TextSize         = 11,
                ZIndex           = 11,
                Parent           = card,
            })
            corner(selBtn, 6)
            stroke(selBtn, T.BorderLight, 1)

            -- Chevron
            mk("TextLabel", {
                Size             = UDim2.fromOffset(16, 26),
                Position         = UDim2.new(1, -20, 0.5, -13),
                BackgroundTransparency = 1,
                Text             = "⌄",
                TextColor3       = T.TextMuted,
                Font             = Enum.Font.GothamBold,
                TextSize         = 12,
                ZIndex           = 12,
                Parent           = card,
            })

            -- Dropdown list
            local open = false
            local list = mk("Frame", {
                Size             = UDim2.new(1, 0, 0, 0),
                Position         = UDim2.new(0, 0, 1, 5),
                BackgroundColor3 = T.CardActive,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = 14,
                Parent           = card,
            })
            corner(list, 8)
            stroke(list, T.BorderLight, 1)
            vList(list, 0)

            local listH = #options * 30

            for _, opt in ipairs(options) do
                local item = mk("TextButton", {
                    Size             = UDim2.new(1, 0, 0, 30),
                    BackgroundColor3 = T.CardActive,
                    BackgroundTransparency = opt == selected and 0 or 1,
                    Text             = opt,
                    TextColor3       = opt == selected and T.Accent or T.TextSub,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 12,
                    ZIndex           = 15,
                    Parent           = list,
                })
                item.MouseEnter:Connect(function() tween(item, {BackgroundTransparency=0, BackgroundColor3=T.CardHover}, 0.1) end)
                item.MouseLeave:Connect(function()
                    tween(item, {BackgroundTransparency = item.Text==selected and 0 or 1}, 0.1)
                end)
                item.Activated:Connect(function()
                    selected = opt
                    selBtn.Text = opt
                    for _, c in ipairs(list:GetChildren()) do
                        if c:IsA("TextButton") then
                            tween(c, {TextColor3 = c.Text==selected and T.Accent or T.TextSub, BackgroundTransparency = c.Text==selected and 0 or 1}, 0.1)
                        end
                    end
                    open = false
                    tween(list, {Size=UDim2.new(1,0,0,0)}, 0.15)
                    task.delay(0.15, function() list.Visible=false end)
                    if cfg3.Callback then cfg3.Callback(opt) end
                end)
            end

            selBtn.Activated:Connect(function()
                open = not open
                if open then
                    list.Visible=true
                    tween(list, {Size=UDim2.new(1,0,0,listH)}, 0.18)
                else
                    tween(list, {Size=UDim2.new(1,0,0,0)}, 0.14)
                    task.delay(0.14, function() list.Visible=false end)
                end
            end)

            return { Get = function() return selected end }
        end

        -------------------------------------------------------------------
        -- Tab:Input
        -------------------------------------------------------------------
        function Tab:Input(cfg3)
            cfg3 = cfg3 or {}
            local card = newCard(58)
            pad(card, 8, 12, 8, 12)

            mk("TextLabel", {
                Size             = UDim2.new(1, 0, 0, 14),
                BackgroundTransparency = 1,
                Text             = (cfg3.Name or "Input"):upper(),
                TextColor3       = T.TextMuted,
                Font             = Enum.Font.GothamBold,
                TextSize         = 9,
                TextXAlignment   = Enum.TextXAlignment.Left,
                LetterSpacing    = 2,
                Parent           = card,
            })
            local box = mk("TextBox", {
                Size             = UDim2.new(1, 0, 0, 28),
                Position         = UDim2.fromOffset(0, 18),
                BackgroundColor3 = T.CardActive,
                Text             = "",
                PlaceholderText  = cfg3.Placeholder or "Enter value...",
                TextColor3       = T.Text,
                PlaceholderColor3 = T.TextMuted,
                Font             = Enum.Font.Gotham,
                TextSize         = 12,
                TextXAlignment   = Enum.TextXAlignment.Left,
                ClearTextOnFocus = false,
                Parent           = card,
            })
            corner(box, 6)
            stroke(box, T.BorderLight, 1)
            pad(box, 0, 8, 0, 8)
            box.FocusLost:Connect(function(enter)
                if cfg3.Callback then cfg3.Callback(box.Text, enter) end
            end)
            return { Get = function() return box.Text end }
        end

        -------------------------------------------------------------------
        -- Tab:Keybind  (keyboard + Mouse1/Mouse2/Mouse3)
        -------------------------------------------------------------------
        function Tab:Keybind(cfg3)
            cfg3 = cfg3 or {}

            -- Normalise Default → {KeyCode, InputType}
            local raw = cfg3.Default or { KeyCode = Enum.KeyCode.Q, InputType = nil }
            local bind
            if typeof(raw) == "EnumItem" then
                bind = { KeyCode = raw, InputType = nil }
            else
                bind = { KeyCode = raw.KeyCode or nil, InputType = raw.InputType or nil }
            end

            local listening = false

            local function label()
                if     bind.InputType == Enum.UserInputType.MouseButton1 then return "Mouse1"
                elseif bind.InputType == Enum.UserInputType.MouseButton2 then return "Mouse2"
                elseif bind.InputType == Enum.UserInputType.MouseButton3 then return "Mouse3"
                elseif bind.KeyCode                                       then return bind.KeyCode.Name
                else return "None" end
            end

            local card = newCard(38)

            mk("TextLabel", {
                Size             = UDim2.new(1, -90, 1, 0),
                Position         = UDim2.fromOffset(14, 0),
                BackgroundTransparency = 1,
                Text             = cfg3.Name or "Keybind",
                TextColor3       = T.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = card,
            })

            local keyBtn = mk("TextButton", {
                Size             = UDim2.fromOffset(76, 26),
                Position         = UDim2.new(1, -88, 0.5, -13),
                BackgroundColor3 = T.CardActive,
                Text             = label(),
                TextColor3       = T.Accent,
                Font             = Enum.Font.GothamBold,
                TextSize         = 11,
                ZIndex           = 2,
                Parent           = card,
            })
            corner(keyBtn, 6)
            stroke(keyBtn, T.BorderLight, 1)

            keyBtn.Activated:Connect(function()
                listening = true
                keyBtn.Text = "· · ·"
                keyBtn.TextColor3 = T.AccentGlow
            end)

            UserInputService.InputBegan:Connect(function(inp, gp)
                if gp or not listening then return end

                local isKB    = inp.UserInputType == Enum.UserInputType.Keyboard
                             and inp.KeyCode ~= Enum.KeyCode.Unknown

                local isMouse = inp.UserInputType == Enum.UserInputType.MouseButton1
                             or inp.UserInputType == Enum.UserInputType.MouseButton2
                             or inp.UserInputType == Enum.UserInputType.MouseButton3

                if isKB then
                    listening = false
                    bind = { KeyCode = inp.KeyCode, InputType = nil }
                    keyBtn.Text = label()
                    keyBtn.TextColor3 = T.Accent
                    if cfg3.Callback then cfg3.Callback(bind) end

                elseif isMouse then
                    listening = false
                    bind = { KeyCode = nil, InputType = inp.UserInputType }
                    keyBtn.Text = label()
                    keyBtn.TextColor3 = T.Accent
                    if cfg3.Callback then cfg3.Callback(bind) end
                end
            end)

            return { Get = function() return bind end }
        end  -- closes Tab:Keybind

        return Tab
    end  -- closes Win:Tab

    -------------------------------------------------------------------
    -- Win:Notify
    -------------------------------------------------------------------
    function Win:Notify(cfg2)
        cfg2 = cfg2 or {}
        local dur = cfg2.Duration or 4

        local holder = sg:FindFirstChild("__nora_notifs") or (function()
            local h = mk("Frame", {
                Name             = "__nora_notifs",
                Size             = UDim2.fromOffset(290, 0),
                Position         = UDim2.new(1, -300, 1, -10),
                AnchorPoint      = Vector2.new(0, 1),
                BackgroundTransparency = 1,
                ZIndex           = 50,
                Parent           = sg,
            })
            vList(h, 6)
            return h
        end)()

        local n = mk("Frame", {
            Size             = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = T.Card,
            ClipsDescendants = true,
            ZIndex           = 51,
            Parent           = holder,
        })
        corner(n, 8)
        stroke(n, T.Border, 1)

        -- Left accent bar
        mk("Frame", {
            Size             = UDim2.fromOffset(3, 9999),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 52,
            Parent           = n,
        })

        local inner = mk("Frame", {
            Size             = UDim2.new(1, -14, 1, 0),
            Position         = UDim2.fromOffset(14, 0),
            BackgroundTransparency = 1,
            ZIndex           = 52,
            Parent           = n,
        })
        pad(inner, 8, 8, 8, 4)

        mk("TextLabel", {
            Size             = UDim2.new(1, 0, 0, 18),
            BackgroundTransparency = 1,
            Text             = cfg2.Title or "Notice",
            TextColor3       = T.Text,
            Font             = Enum.Font.GothamBold,
            TextSize         = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 53,
            Parent           = inner,
        })
        mk("TextLabel", {
            Size             = UDim2.new(1, 0, 0, 14),
            Position         = UDim2.fromOffset(0, 20),
            BackgroundTransparency = 1,
            Text             = cfg2.Message or "",
            TextColor3       = T.TextSub,
            Font             = Enum.Font.Gotham,
            TextSize         = 11,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 53,
            Parent           = inner,
        })

        tween(n, {Size=UDim2.new(1,0,0,56)}, 0.2)
        task.delay(dur, function()
            tween(n, {Size=UDim2.new(1,0,0,0)}, 0.18)
            task.delay(0.2, function() n:Destroy() end)
        end)
    end

    -- Toggle key
    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.KeyCode == toggleKey then
            main.Visible = not main.Visible
        end
    end)

    return Win
end

return NoraLib
