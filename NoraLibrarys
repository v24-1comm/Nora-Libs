                Size             = UDim2.new(0.5, 0, 1, 0),
                Position         = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text             = cfg.Name or "Dropdown",
                TextColor3       = theme.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = frame,
            })

            local selLbl = makeInst("TextButton", {
                Size             = UDim2.new(0, 100, 0, 24),
                Position         = UDim2.new(1, -112, 0.5, -12),
                BackgroundColor3 = theme.Surface3,
                Text             = selected,
                TextColor3       = theme.Accent,
                Font             = Enum.Font.GothamSemibold,
                TextSize         = 11,
                ZIndex           = 11,
                Parent           = frame,
            })
            corner(selLbl, 5)
            stroke(selLbl, theme.Border, 1)

            -- Dropdown list
            local open = false
            local list = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 0),
                Position         = UDim2.new(0, 0, 1, 4),
                BackgroundColor3 = theme.Surface,
                BorderSizePixel  = 0,
                ClipsDescendants = true,
                Visible          = false,
                ZIndex           = 12,
                Parent           = frame,
            })
            corner(list, 6)
            stroke(list, theme.Border, 1)

            local listLayout2 = listLayout(list, nil, 0)
            listLayout2.Padding = UDim.new(0, 0)

            local function setSelected(opt)
                selected = opt
                selLbl.Text = opt
                if cfg.Callback then cfg.Callback(opt) end
            end

            for _, opt in ipairs(options) do
                local oi = makeInst("TextButton", {
                    Size             = UDim2.new(1, 0, 0, 30),
                    BackgroundColor3 = theme.Surface2,
                    Text             = opt,
                    TextColor3       = opt == selected and theme.Accent or theme.TextMuted,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 12,
                    ZIndex           = 13,
                    Parent           = list,
                })
                oi.Activated:Connect(function()
                    setSelected(opt)
                    -- reset colors
                    for _, c in ipairs(list:GetChildren()) do
                        if c:IsA("TextButton") then
                            c.TextColor3 = c.Text == selected and theme.Accent or theme.TextMuted
                        end
                    end
                    -- close
                    open = false
                    tween(list, { Size = UDim2.new(1, 0, 0, 0) }, 0.15)
                    task.delay(0.15, function() list.Visible = false end)
                end)
            end

            local listH = #options * 30

            selLbl.Activated:Connect(function()
                open = not open
                if open then
                    list.Visible = true
                    tween(list, { Size = UDim2.new(1, 0, 0, listH) }, 0.2)
                else
                    tween(list, { Size = UDim2.new(1, 0, 0, 0) }, 0.15)
                    task.delay(0.15, function() list.Visible = false end)
                end
            end)

            return { Get = function() return selected end, Set = setSelected }
        end

        -- ── Tab:Input{} ──
        function Tab:Input(cfg)
            cfg = cfg or {}
            local frame = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 58),
                BackgroundColor3 = theme.Surface2,
                BorderSizePixel  = 0,
                LayoutOrder      = #page:GetChildren(),
                Parent           = page,
            })
            corner(frame, 6)
            stroke(frame, theme.Border, 1)
            padding(frame, 8, 12, 8, 12)

            makeInst("TextLabel", {
                Size             = UDim2.new(1, 0, 0, 14),
                BackgroundTransparency = 1,
                Text             = (cfg.Name or "Input"):upper(),
                TextColor3       = theme.TextMuted,
                Font             = Enum.Font.GothamBold,
                TextSize         = 10,
                TextXAlignment   = Enum.TextXAlignment.Left,
                LetterSpacing    = 2,
                Parent           = frame,
            })

            local box = makeInst("TextBox", {
                Size             = UDim2.new(1, 0, 0, 28),
                Position         = UDim2.fromOffset(0, 18),
                BackgroundColor3 = theme.Surface3,
                Text             = "",
                PlaceholderText  = cfg.Placeholder or "Type here...",
                TextColor3       = theme.Text,
                PlaceholderColor3 = theme.TextMuted,
                Font             = Enum.Font.Gotham,
                TextSize         = 12,
                TextXAlignment   = Enum.TextXAlignment.Left,
                ClearTextOnFocus = false,
                Parent           = frame,
            })
            corner(box, 5)
            stroke(box, theme.Border, 1)
            padding(box, 0, 8, 0, 8)

            box.FocusLost:Connect(function(enter)
                if cfg.Callback then cfg.Callback(box.Text, enter) end
            end)

            return { Get = function() return box.Text end }
        end

        -- ── Tab:ColorPicker{} ──
        function Tab:ColorPicker(cfg)
            cfg = cfg or {}
            local currentColor = cfg.Default or Color3.fromRGB(108, 99, 255)

            local row = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = theme.Surface2,
                BorderSizePixel  = 0,
                LayoutOrder      = #page:GetChildren(),
                Parent           = page,
            })
            corner(row, 6)
            stroke(row, theme.Border, 1)

            makeInst("TextLabel", {
                Size             = UDim2.new(1, -60, 1, 0),
                Position         = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text             = cfg.Name or "Color",
                TextColor3       = theme.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = row,
            })

            local swatch = makeInst("Frame", {
                Size             = UDim2.fromOffset(48, 22),
                Position         = UDim2.new(1, -58, 0.5, -11),
                BackgroundColor3 = currentColor,
                BorderSizePixel  = 0,
                Parent           = row,
            })
            corner(swatch, 5)
            stroke(swatch, theme.Border, 1)

            -- (A full HSV picker would be a separate component; swatch shown for preview)
            return {
                Get = function() return currentColor end,
                Set = function(c) currentColor = c; swatch.BackgroundColor3 = c; if cfg.Callback then cfg.Callback(c) end end
            }
        end

        -- ── Tab:Keybind{} ──
        function Tab:Keybind(cfg)
            cfg = cfg or {}

            -- Normalise whatever was passed as Default into {KeyCode, InputType}
            local defaultRaw = cfg.Default or { KeyCode = Enum.KeyCode.Q, InputType = nil }
            local bind
            if typeof(defaultRaw) == "EnumItem" then
                bind = { KeyCode = defaultRaw, InputType = nil }
            else
                bind = { KeyCode = defaultRaw.KeyCode or nil, InputType = defaultRaw.InputType or nil }
            end

            local binding = false

            -- Helper: human-readable label for current bind
            local function bindLabel()
                if bind.InputType == Enum.UserInputType.MouseButton1 then return "Mouse1"
                elseif bind.InputType == Enum.UserInputType.MouseButton2 then return "Mouse2"
                elseif bind.InputType == Enum.UserInputType.MouseButton3 then return "Mouse3"
                elseif bind.KeyCode then return bind.KeyCode.Name
                else return "None" end
            end

            local row = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = theme.Surface2,
                BorderSizePixel  = 0,
                LayoutOrder      = #page:GetChildren(),
                Parent           = page,
            })
            corner(row, 6)
            stroke(row, theme.Border, 1)

            makeInst("TextLabel", {
                Size             = UDim2.new(1, -80, 1, 0),
                Position         = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text             = cfg.Name or "Keybind",
                TextColor3       = theme.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = row,
            })

            local keyBtn = makeInst("TextButton", {
                Size             = UDim2.fromOffset(72, 24),
                Position         = UDim2.new(1, -82, 0.5, -12),
                BackgroundColor3 = theme.Surface3,
                Text             = bindLabel(),   -- FIX: was `key.Name` (undefined)
                TextColor3       = theme.TextMuted,
                Font             = Enum.Font.GothamBold,
                TextSize         = 11,
                Parent           = row,
            })
            corner(keyBtn, 5)
            stroke(keyBtn, theme.Border, 1)

            keyBtn.Activated:Connect(function()
                binding = true
                keyBtn.Text = "..."
                keyBtn.TextColor3 = theme.Accent
            end)

            -- FIX: removed the broken second `local bind = { KeyCode = key, ... }` declaration
            -- FIX: InputBegan now properly handles Mouse1/Mouse2/Mouse3 AND keyboard keys
            UserInputService.InputBegan:Connect(function(inp, gp)
                if gp then return end

                -- CAPTURE MODE: user is choosing a new bind
                if binding then
                    local isKeyboard = inp.UserInputType == Enum.UserInputType.Keyboard
                        and inp.KeyCode ~= Enum.KeyCode.Unknown

                    local isMouse = inp.UserInputType == Enum.UserInputType.MouseButton1
                        or inp.UserInputType == Enum.UserInputType.MouseButton2
                        or inp.UserInputType == Enum.UserInputType.MouseButton3

                    if isKeyboard then
                        binding = false
                        bind = { KeyCode = inp.KeyCode, InputType = nil }
                        keyBtn.Text = inp.KeyCode.Name
                        keyBtn.TextColor3 = theme.TextMuted
                        if cfg.Callback then cfg.Callback(bind) end

                    elseif isMouse then
                        binding = false
                        bind = { KeyCode = nil, InputType = inp.UserInputType }
                        keyBtn.Text = bindLabel()
                        keyBtn.TextColor3 = theme.TextMuted
                        if cfg.Callback then cfg.Callback(bind) end
                    end
                    return
                end

                -- NORMAL USE: detect if bound key/button was pressed
                local pressed =
                    (bind.KeyCode   and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == bind.KeyCode) or
                    (bind.InputType and inp.UserInputType == bind.InputType)

                if pressed and cfg.Callback then
                    cfg.Callback(bind)
                end
            end)

            return { Get = function() return bind end }
        end  -- closes Tab:Keybind

        return Tab  -- FIX: was completely missing — Win:Tab() was returning nil, crashing every :Section/:Toggle/:Keybind call
    end  -- FIX: closes Win:Tab — was missing, causing Win:Notify to be nested inside Win:Tab

    -- ── Win:Notify{} ──
    function Win:Notify(cfg)
        cfg = cfg or {}
        local dur = cfg.Duration or 4

        local notifHolder = main:FindFirstChild("__notif_holder") or (function()
            local h = makeInst("Frame", {
                Name             = "__notif_holder",
                Size             = UDim2.new(0, 280, 1, -10),
                Position         = UDim2.new(1, -(280+8), 0, 5),
                BackgroundTransparency = 1,
                ZIndex           = 100,
                Parent           = main,
            })
            listLayout(h, nil, 6)
            return h
        end)()

        local n = makeInst("Frame", {
            Size             = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = theme.Surface,
            BorderSizePixel  = 0,
            ClipsDescendants = true,
            ZIndex           = 100,
            Parent           = notifHolder,
        })
        corner(n, 7)

        -- Left accent bar
        makeInst("Frame", {
            Size             = UDim2.new(0, 3, 1, 0),
            BackgroundColor3 = theme.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 101,
            Parent           = n,
        })
        stroke(n, theme.Border, 1)

        local inner = makeInst("Frame", {
            Size             = UDim2.new(1, -12, 1, 0),
            Position         = UDim2.fromOffset(12, 0),
            BackgroundTransparency = 1,
            ZIndex           = 101,
            Parent           = n,
        })
        padding(inner, 8, 8, 8, 4)

        makeInst("TextLabel", {
            Size             = UDim2.new(1, 0, 0, 18),
            BackgroundTransparency = 1,
            Text             = cfg.Title or "Notice",
            TextColor3       = theme.Text,
            Font             = Enum.Font.GothamBold,
            TextSize         = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 102,
            Parent           = inner,
        })
        makeInst("TextLabel", {
            Size             = UDim2.new(1, 0, 0, 14),
            Position         = UDim2.fromOffset(0, 20),
            BackgroundTransparency = 1,
            Text             = cfg.Message or "",
            TextColor3       = theme.TextMuted,
            Font             = Enum.Font.Gotham,
            TextSize         = 11,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 102,
            Parent           = inner,
        })

        tween(n, { Size = UDim2.new(1, 0, 0, 52) }, 0.2)
        task.delay(dur, function()
            tween(n, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
            task.delay(0.25, function() n:Destroy() end)
        end)
    end

    -- Toggle visibility with a key (default RightShift)
    local toggleKey = cfg.ToggleKey or Enum.KeyCode.RightShift
    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.KeyCode == toggleKey then
            main.Visible = not main.Visible
        end
    end)

    return Win
end

return NoraLib
