            local knob = makeInst("Frame", {
                Size             = UDim2.fromOffset(14, 14),
                Position         = state and UDim2.fromOffset(19, 3) or UDim2.fromOffset(3, 3),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                Parent           = pill,
            })
            corner(knob, 7)

            local function setToggle(val)
                state = val
                tween(pill, { BackgroundColor3 = val and theme.Accent or theme.Surface3 }, 0.15)
                tween(knob, { Position = val and UDim2.fromOffset(19, 3) or UDim2.fromOffset(3, 3) }, 0.15)
                if cfg.Callback then cfg.Callback(val) end
            end

            local clickArea = makeInst("TextButton", {
                Size             = UDim2.fromScale(1, 1),
                BackgroundTransparency = 1,
                Text             = "",
                Parent           = row,
            })
            clickArea.Activated:Connect(function() setToggle(not state) end)

            return { Set = setToggle, Get = function() return state end }
        end

        -- ── Tab:Slider{} ──
        function Tab:Slider(cfg)
            cfg = cfg or {}
            local min  = cfg.Min     or 0
            local max  = cfg.Max     or 100
            local val  = cfg.Default or min
            local prec = cfg.Precision or 0

            local frame = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 52),
                BackgroundColor3 = theme.Surface2,
                BorderSizePixel  = 0,
                LayoutOrder      = #page:GetChildren(),
                Parent           = page,
            })
            corner(frame, 6)
            stroke(frame, theme.Border, 1)
            padding(frame, 8, 12, 8, 12)

            local topRow = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 18),
                BackgroundTransparency = 1,
                Parent           = frame,
            })
            makeInst("TextLabel", {
                Size             = UDim2.new(0.7, 0, 1, 0),
                BackgroundTransparency = 1,
                Text             = cfg.Name or "Slider",
                TextColor3       = theme.Text,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                TextXAlignment   = Enum.TextXAlignment.Left,
                Parent           = topRow,
            })
            local valLbl = makeInst("TextLabel", {
                Size             = UDim2.new(0.3, 0, 1, 0),
                Position         = UDim2.fromScale(0.7, 0),
                BackgroundTransparency = 1,
                Text             = tostring(val),
                TextColor3       = theme.Accent,
                Font             = Enum.Font.GothamBold,
                TextSize         = 12,
                TextXAlignment   = Enum.TextXAlignment.Right,
                Parent           = topRow,
            })

            -- Track
            local track = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 4),
                Position         = UDim2.new(0, 0, 0, 30),
                BackgroundColor3 = theme.Surface3,
                BorderSizePixel  = 0,
                Parent           = frame,
            })
            corner(track, 2)

            -- Fill
            local fillRatio = (val - min) / (max - min)
            local fill = makeInst("Frame", {
                Size             = UDim2.new(fillRatio, 0, 1, 0),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel  = 0,
                Parent           = track,
            })
            corner(fill, 2)

            -- Knob
            local knob = makeInst("Frame", {
                Size             = UDim2.fromOffset(14, 14),
                Position         = UDim2.new(fillRatio, -7, 0.5, -7),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel  = 0,
                ZIndex           = 2,
                Parent           = track,
            })
            corner(knob, 7)

            local dragging2 = false

            local function updateSlider(x)
                local abs  = track.AbsolutePosition.X
                local width = track.AbsoluteSize.X
                local r = math.clamp((x - abs) / width, 0, 1)
                local v = min + (max - min) * r
                v = math.round(v * 10^prec) / 10^prec
                val = v
                valLbl.Text = tostring(v)
                tween(fill,  { Size = UDim2.new(r, 0, 1, 0) }, 0.05)
                tween(knob,  { Position = UDim2.new(r, -7, 0.5, -7) }, 0.05)
                if cfg.Callback then cfg.Callback(v) end
            end

            local hitbox = makeInst("TextButton", {
                Size             = UDim2.new(1, 0, 0, 20),
                Position         = UDim2.new(0, 0, 0, 22),
                BackgroundTransparency = 1,
                Text             = "",
                ZIndex           = 3,
                Parent           = frame,
            })
            hitbox.MouseButton1Down:Connect(function()
                dragging2 = true
                updateSlider(Mouse.X)
            end)
            UserInputService.InputChanged:Connect(function(inp)
                if dragging2 and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(Mouse.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging2 = false
                end
            end)

            return { Get = function() return val end }
        end

        -- ── Tab:Dropdown{} ──
        function Tab:Dropdown(cfg)
            cfg = cfg or {}
            local options  = cfg.Options  or {}
            local selected = cfg.Default  or (options[1] or "")

            local frame = makeInst("Frame", {
                Size             = UDim2.new(1, 0, 0, 36),
