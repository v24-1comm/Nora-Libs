            end

            -- Pill
            local pill=mk("Frame",{
                Size=UDim2.fromOffset(38,21),
                Position=UDim2.new(1,-50,0.5,-10),
                BackgroundColor3=state and C.Accent or C.CardSel,
                BorderSizePixel=0,Parent=card,
            }); rnd(pill,11)

            local knob=mk("Frame",{
                Size=UDim2.fromOffset(15,15),
                Position=state and UDim2.fromOffset(20,3) or UDim2.fromOffset(3,3),
                BackgroundColor3=Color3.new(1,1,1),
                BorderSizePixel=0,Parent=pill,
            }); rnd(knob,8)

            local function set(v)
                state=v
                tw(pill,{BackgroundColor3=v and C.Accent or C.CardSel},0.15)
                tw(knob,{Position=v and UDim2.fromOffset(20,3) or UDim2.fromOffset(3,3)},0.15)
                if cfg.Callback then cfg.Callback(v) end
            end

            local hit=mk("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",Parent=card})
            hit.Activated:Connect(function() set(not state) end)
            hit.MouseEnter:Connect(function() tw(card,{BackgroundColor3=C.CardHov},0.1) end)
            hit.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.Card},0.1) end)

            return {Set=set, Get=function() return state end}
        end

        ---------------------------------------------------------------
        -- Tab:Slider
        ---------------------------------------------------------------
        function Tab:Slider(cfg)
            cfg=cfg or {}
            local mn=cfg.Min or 0; local mx=cfg.Max or 100
            local val=cfg.Default or mn; local prec=cfg.Precision or 0

            local card=newCard(58); pdg(card,10,14,10,14)

            mk("TextLabel",{
                Size=UDim2.new(0.6,0,0,18),
                BackgroundTransparency=1,
                Text=cfg.Name or "Slider",
                TextColor3=C.Text,
                Font=Enum.Font.GothamBold,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,
                Parent=card,
            })
            local valLbl=mk("TextLabel",{
                Size=UDim2.new(0.4,0,0,18),
                Position=UDim2.fromScale(0.6,0),
                BackgroundTransparency=1,
                Text=tostring(val),
                TextColor3=C.Accent,
                Font=Enum.Font.GothamBold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Right,
                Parent=card,
            })

            local track=mk("Frame",{
                Size=UDim2.new(1,0,0,5),
                Position=UDim2.new(0,0,0,30),
                BackgroundColor3=C.CardSel,
                BorderSizePixel=0,Parent=card,
            }); rnd(track,3)

            local r0=(val-mn)/(mx-mn)
            local fill=mk("Frame",{
                Size=UDim2.new(r0,0,1,0),
                BackgroundColor3=C.Accent,
                BorderSizePixel=0,Parent=track,
            }); rnd(fill,3)

            local knob=mk("Frame",{
                Size=UDim2.fromOffset(15,15),
                Position=UDim2.new(r0,-7,0.5,-7),
                BackgroundColor3=Color3.new(1,1,1),
                BorderSizePixel=0,ZIndex=2,Parent=track,
            }); rnd(knob,8)
            mk("UIStroke",{Color=C.Accent,Thickness=2,Parent=knob})

            local dragging=false
            local function update(x)
                local r=math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
                local v=math.round((mn+(mx-mn)*r)*10^prec)/10^prec
                val=v; valLbl.Text=tostring(v)
                tw(fill,{Size=UDim2.new(r,0,1,0)},0.04)
                tw(knob,{Position=UDim2.new(r,-7,0.5,-7)},0.04)
                if cfg.Callback then cfg.Callback(v) end
            end

            local hit=mk("TextButton",{
                Size=UDim2.new(1,0,0,24),
                Position=UDim2.new(0,0,0,22),
                BackgroundTransparency=1,Text="",ZIndex=3,Parent=card,
            })
            hit.MouseButton1Down:Connect(function() dragging=true; update(Mouse.X) end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then update(Mouse.X) end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
            end)

            return {Get=function() return val end}
        end

        ---------------------------------------------------------------
        -- Tab:Dropdown
        ---------------------------------------------------------------
        function Tab:Dropdown(cfg)
            cfg=cfg or {}
            local opts=cfg.Options or {}
            local sel=cfg.Default or (opts[1] or "")

            local card=newCard(38)
            card.ClipsDescendants=false; card.ZIndex=10

            mk("TextLabel",{
                Size=UDim2.new(0.5,0,1,0),
                Position=UDim2.fromOffset(14,0),
                BackgroundTransparency=1,
                Text=cfg.Name or "Dropdown",
                TextColor3=C.Text,
                Font=Enum.Font.GothamBold,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,
                Parent=card,
            })

            local selBtn=mk("TextButton",{
                Size=UDim2.fromOffset(108,26),
                Position=UDim2.new(1,-118,0.5,-13),
                BackgroundColor3=C.CardSel,
                Text=sel,TextColor3=C.Accent,
                Font=Enum.Font.GothamSemibold,TextSize=11,
                ZIndex=11,Parent=card,
            }); rnd(selBtn,6); bdr(selBtn,C.BorderLt,1)

            local open=false
            local list=mk("Frame",{
                Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,1,4),
                BackgroundColor3=C.CardSel,
                BorderSizePixel=0,
                ClipsDescendants=true,
                Visible=false,
                ZIndex=14,Parent=card,
            }); rnd(list,8); bdr(list,C.BorderLt,1)
            vlay(list,0)

            local listH=#opts*30
            for _,opt in ipairs(opts) do
                local item=mk("TextButton",{
                    Size=UDim2.new(1,0,0,30),
                    BackgroundColor3=opt==sel and C.CardHov or C.CardSel,
                    Text=opt,TextColor3=opt==sel and C.Accent or C.TextSub,
                    Font=Enum.Font.GothamSemibold,TextSize=12,
                    ZIndex=15,Parent=list,
                })
                item.MouseEnter:Connect(function() tw(item,{BackgroundColor3=C.CardHov},0.08) end)
                item.MouseLeave:Connect(function()
                    tw(item,{BackgroundColor3=item.Text==sel and C.CardHov or C.CardSel},0.08)
                end)
                item.Activated:Connect(function()
                    sel=opt; selBtn.Text=opt
                    for _,c in ipairs(list:GetChildren()) do
                        if c:IsA("TextButton") then
                            tw(c,{TextColor3=c.Text==sel and C.Accent or C.TextSub,
                                  BackgroundColor3=c.Text==sel and C.CardHov or C.CardSel},0.08)
                        end
                    end
                    open=false
                    tw(list,{Size=UDim2.new(1,0,0,0)},0.14)
                    task.delay(0.14,function() list.Visible=false end)
                    if cfg.Callback then cfg.Callback(opt) end
                end)
            end

            selBtn.Activated:Connect(function()
                open=not open
                if open then list.Visible=true; tw(list,{Size=UDim2.new(1,0,0,listH)},0.18)
                else tw(list,{Size=UDim2.new(1,0,0,0)},0.14); task.delay(0.14,function() list.Visible=false end) end
            end)

            return {Get=function() return sel end}
        end

