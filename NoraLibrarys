    -- ── Win:Tab{} ─────────────────────────────────────────────────
    function Win:Tab(cfg2)
        cfg2 = cfg2 or {}
        local tabName = (type(cfg2) == "string") and cfg2 or (cfg2.Name or "Tab")
        local tabIcon = (type(cfg2) == "table")  and (cfg2.Icon or "") or ""
        local isFirst = #self._tabs == 0

        -- Sidebar button
        local tabBtn = mk("TextButton", {
            Size             = UDim2.new(1, -16, 0, 36),
            BackgroundColor3 = isFirst and T.CardActive or Color3.new(0,0,0),
            BackgroundTransparency = isFirst and 0 or 1,
            Text             = "",
            AutoButtonColor  = false,
            ZIndex           = 3,
            LayoutOrder      = #sidebar:GetChildren(),
            Parent           = sidebar,
        })
        corner(tabBtn, 7)

        -- Accent left bar (only visible on active)
        local activeBar = mk("Frame", {
            Size             = UDim2.fromOffset(3, 18),
            Position         = UDim2.new(0, 2, 0.5, -9),
            BackgroundColor3 = T.Accent,
            BackgroundTransparency = isFirst and 0 or 1,
            BorderSizePixel  = 0,
            ZIndex           = 4,
            Parent           = tabBtn,
        })
        corner(activeBar, 2)

        -- Icon
        if tabIcon ~= "" then
            mk("TextLabel", {
                Size             = UDim2.fromOffset(18, 36),
                Position         = UDim2.fromOffset(12, 0),
                BackgroundTransparency = 1,
                Text             = tabIcon,
                TextColor3       = isFirst and T.Text or T.TextMuted,
                Font             = Enum.Font.GothamBold,
                TextSize         = 14,
                ZIndex           = 4,
                Parent           = tabBtn,
            })
        end

        -- Label
        local tabLbl = mk("TextLabel", {
            Size             = UDim2.new(1, -(tabIcon ~= "" and 36 or 16), 1, 0),
            Position         = UDim2.fromOffset(tabIcon ~= "" and 34 or 12, 0),
            BackgroundTransparency = 1,
            Text             = tabName,
            TextColor3       = isFirst and T.Text or T.TextMuted,
            Font             = Enum.Font.GothamBold,
            TextSize         = 12,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 4,
            Parent           = tabBtn,
        })

        -- Content scrolling page
        local page = mk("ScrollingFrame", {
            Size                 = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            BorderSizePixel      = 0,
            ScrollBarThickness   = 3,
            ScrollBarImageColor3 = T.BorderLight,
            CanvasSize           = UDim2.new(1, 0, 0, 0),
            AutomaticCanvasSize  = Enum.AutomaticSize.Y,
            Visible              = isFirst,
            Parent               = contentHost,
        })
        pad(page, 12, 14, 12, 14)
        vList(page, 7)

        -- Tab object
        local Tab = { _btn = tabBtn, _page = page }

        local function activate()
            for _, t in ipairs(Win._tabs) do
                t._page.Visible = false
                tween(t._btn,  {BackgroundTransparency=1, BackgroundColor3=T.CardActive}, 0.15)
                -- find lbl and bar children
                for _, c in ipairs(t._btn:GetChildren()) do
                    if c:IsA("TextLabel") then tween(c, {TextColor3=T.TextMuted}, 0.15) end
                    if c:IsA("Frame")     then tween(c, {BackgroundTransparency=1}, 0.15) end
                end
            end
            page.Visible = true
            tween(tabBtn, {BackgroundTransparency=0, BackgroundColor3=T.CardActive}, 0.15)
            for _, c in ipairs(tabBtn:GetChildren()) do
                if c:IsA("TextLabel") then tween(c, {TextColor3=T.Text}, 0.15) end
                if c:IsA("Frame")     then tween(c, {BackgroundTransparency=0}, 0.15) end
            end
            Win._activeTab = Tab
        end

        tabBtn.Activated:Connect(activate)
        tabBtn.MouseEnter:Connect(function()
            if Win._activeTab ~= Tab then
                tween(tabBtn, {BackgroundTransparency=0, BackgroundColor3=T.Card}, 0.12)
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if Win._activeTab ~= Tab then
                tween(tabBtn, {BackgroundTransparency=1}, 0.12)
            end
        end)

        if isFirst then Win._activeTab = Tab end
        table.insert(Win._tabs, Tab)

