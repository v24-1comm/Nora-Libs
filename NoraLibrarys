    --[[ ── Win:Tab ]] -----------------------------------------------------
    function Win:Tab(arg)
        local name = type(arg)=="string" and arg or (arg and arg.Name or "Tab")
        local icon = type(arg)=="table"  and (arg.Icon or "") or ""
        local isFirst = #self._tabs==0

        -- Sidebar button (absolute position, no layout manager)
        local btn=mk("TextButton",{
            Size=UDim2.new(1,-16,0,36),
            Position=UDim2.new(0,8,0,self._tabY),
            BackgroundColor3=isFirst and C.CardSel or C.Sidebar,
            Text="",
            AutoButtonColor=false,
            ZIndex=5,
            Parent=sidebar,
        }); rnd(btn,7)
        self._tabY = self._tabY + 40   -- next button Y

        -- Active accent bar (left edge of button)
        local accentBar=mk("Frame",{
            Size=UDim2.fromOffset(3,18),
            Position=UDim2.new(0,2,0.5,-9),
            BackgroundColor3=C.Accent,
            BackgroundTransparency=isFirst and 0 or 1,
            BorderSizePixel=0,
            ZIndex=6,
            Parent=btn,
        }); rnd(accentBar,2)

        -- Icon label
        local iconLbl
        if icon~="" then
            iconLbl=mk("TextLabel",{
                Size=UDim2.fromOffset(20,36),
                Position=UDim2.fromOffset(10,0),
                BackgroundTransparency=1,
                Text=icon,
                TextColor3=isFirst and C.Text or C.TextMut,
                Font=Enum.Font.GothamBold,TextSize=14,
                ZIndex=6,Parent=btn,
            })
        end

        -- Name label
        local nameLbl=mk("TextLabel",{
            Size=UDim2.new(1,-(icon~="" and 34 or 14),1,0),
            Position=UDim2.fromOffset(icon~="" and 32 or 12,0),
            BackgroundTransparency=1,
            Text=name,
            TextColor3=isFirst and C.Text or C.TextMut,
            Font=Enum.Font.GothamBold,TextSize=12,
            TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=6,Parent=btn,
        })

        -- Scroll page for this tab
        local page=mk("ScrollingFrame",{
            Size=UDim2.fromScale(1,1),
            BackgroundTransparency=1,
            BorderSizePixel=0,
            ScrollBarThickness=3,
            ScrollBarImageColor3=C.BorderLt,
            CanvasSize=UDim2.new(1,0,0,0),
            AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=isFirst,
            ClipsDescendants=true,
            ZIndex=3,
            Parent=content,
        })
        pdg(page,12,14,12,14)
        vlay(page,7)

        -- Tab record
        local Tab={_btn=btn,_page=page,_accentBar=accentBar,_nameLbl=nameLbl,_iconLbl=iconLbl}

        local function activate()
            for _,t in ipairs(Win._tabs) do
                t._page.Visible=false
                tw(t._btn,{BackgroundColor3=C.Sidebar},0.15)
                tw(t._accentBar,{BackgroundTransparency=1},0.15)
                tw(t._nameLbl,{TextColor3=C.TextMut},0.15)
                if t._iconLbl then tw(t._iconLbl,{TextColor3=C.TextMut},0.15) end
            end
            page.Visible=true
            tw(btn,{BackgroundColor3=C.CardSel},0.15)
            tw(accentBar,{BackgroundTransparency=0},0.15)
            tw(nameLbl,{TextColor3=C.Text},0.15)
            if iconLbl then tw(iconLbl,{TextColor3=C.Text},0.15) end
            Win._active=Tab
        end

        btn.Activated:Connect(activate)
        btn.MouseEnter:Connect(function()
            if Win._active~=Tab then tw(btn,{BackgroundColor3=C.Card},0.1) end
        end)
        btn.MouseLeave:Connect(function()
            if Win._active~=Tab then tw(btn,{BackgroundColor3=C.Sidebar},0.1) end
        end)

        if isFirst then Win._active=Tab end
        table.insert(Win._tabs,Tab)

        -- Shared: next layout order counter (avoids counting mixed children)
        local _order=0
        local function nextOrder() _order=_order+1; return _order end

        local function newCard(h)
            local card=mk("Frame",{
                Size=UDim2.new(1,0,0,h),
                BackgroundColor3=C.Card,
                BorderSizePixel=0,
                LayoutOrder=nextOrder(),
                Parent=page,
            }); rnd(card,8); bdr(card,C.Border,1)
            return card
        end

