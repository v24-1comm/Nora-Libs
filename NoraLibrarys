        function Tab:Input(cfg)
            cfg=cfg or {}
            local card=newCard(58); pdg(card,8,12,8,12)
            mk("TextLabel",{
                Size=UDim2.new(1,0,0,14),
                BackgroundTransparency=1,
                Text=(cfg.Name or "Input"):upper(),
                TextColor3=C.TextMut,
                Font=Enum.Font.GothamBold,TextSize=9,
                TextXAlignment=Enum.TextXAlignment.Left,
                Parent=card,
            })
            local box=mk("TextBox",{
                Size=UDim2.new(1,0,0,28),
                Position=UDim2.fromOffset(0,18),
                BackgroundColor3=C.CardSel,
                Text="",PlaceholderText=cfg.Placeholder or "Enter value...",
                TextColor3=C.Text,PlaceholderColor3=C.TextMut,
                Font=Enum.Font.Gotham,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,
                ClearTextOnFocus=false,
                Parent=card,
            }); rnd(box,6); bdr(box,C.BorderLt,1); pdg(box,0,8,0,8)
            box.FocusLost:Connect(function(enter)
                if cfg.Callback then cfg.Callback(box.Text,enter) end
            end)
            return {Get=function() return box.Text end}
        end

        ---------------------------------------------------------------
        -- Tab:Keybind  (keyboard + Mouse1 / Mouse2 / Mouse3)
        ---------------------------------------------------------------
        function Tab:Keybind(cfg)
            cfg=cfg or {}
            local raw=cfg.Default or {KeyCode=Enum.KeyCode.Q,InputType=nil}
            local bind
            if typeof(raw)=="EnumItem" then
                bind={KeyCode=raw,InputType=nil}
            else
                bind={KeyCode=raw.KeyCode or nil,InputType=raw.InputType or nil}
            end

            local listening=false

            local function lbl()
                if bind.InputType==Enum.UserInputType.MouseButton1 then return "Mouse1"
                elseif bind.InputType==Enum.UserInputType.MouseButton2 then return "Mouse2"
                elseif bind.InputType==Enum.UserInputType.MouseButton3 then return "Mouse3"
                elseif bind.KeyCode then return bind.KeyCode.Name
                else return "None" end
            end

            local card=newCard(38)
            mk("TextLabel",{
                Size=UDim2.new(1,-92,1,0),
                Position=UDim2.fromOffset(14,0),
                BackgroundTransparency=1,
                Text=cfg.Name or "Keybind",
                TextColor3=C.Text,
                Font=Enum.Font.GothamBold,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,
                Parent=card,
            })
            local keyBtn=mk("TextButton",{
                Size=UDim2.fromOffset(76,26),
                Position=UDim2.new(1,-88,0.5,-13),
                BackgroundColor3=C.CardSel,
                Text=lbl(),TextColor3=C.Accent,
                Font=Enum.Font.GothamBold,TextSize=11,
                ZIndex=2,Parent=card,
            }); rnd(keyBtn,6); bdr(keyBtn,C.BorderLt,1)

            keyBtn.Activated:Connect(function()
                listening=true
                keyBtn.Text="· · ·"
                keyBtn.TextColor3=C.AccentHi
            end)

            UserInputService.InputBegan:Connect(function(inp,gp)
                if gp or not listening then return end
                local isKB = inp.UserInputType==Enum.UserInputType.Keyboard
                          and inp.KeyCode~=Enum.KeyCode.Unknown
                local isMB = inp.UserInputType==Enum.UserInputType.MouseButton1
                          or inp.UserInputType==Enum.UserInputType.MouseButton2
                          or inp.UserInputType==Enum.UserInputType.MouseButton3
                if isKB then
                    listening=false
                    bind={KeyCode=inp.KeyCode,InputType=nil}
                    keyBtn.Text=lbl(); keyBtn.TextColor3=C.Accent
                    if cfg.Callback then cfg.Callback(bind) end
                elseif isMB then
                    listening=false
                    bind={KeyCode=nil,InputType=inp.UserInputType}
                    keyBtn.Text=lbl(); keyBtn.TextColor3=C.Accent
                    if cfg.Callback then cfg.Callback(bind) end
                end
            end)

            return {Get=function() return bind end}
        end  -- Tab:Keybind

        return Tab
    end  -- Win:Tab

    ---------------------------------------------------------------
    -- Win:Notify
    ---------------------------------------------------------------
    function Win:Notify(cfg)
        cfg=cfg or {}
        local dur=cfg.Duration or 4

        local holder=sg:FindFirstChild("__notifs") or (function()
            local h=mk("Frame",{
                Name="__notifs",
                Size=UDim2.fromOffset(280,0),
                Position=UDim2.new(1,-290,1,-10),
                AnchorPoint=Vector2.new(0,1),
                BackgroundTransparency=1,
                ZIndex=50,Parent=sg,
            })
            local ll=Instance.new("UIListLayout")
            ll.FillDirection=Enum.FillDirection.Vertical
            ll.VerticalAlignment=Enum.VerticalAlignment.Bottom
            ll.SortOrder=Enum.SortOrder.LayoutOrder
            ll.Padding=UDim.new(0,6)
            ll.Parent=h
            return h
        end)()

        local n=mk("Frame",{
            Size=UDim2.new(1,0,0,0),
            BackgroundColor3=C.Card,
            ClipsDescendants=true,
            ZIndex=51,Parent=holder,
        }); rnd(n,8); bdr(n,C.Border,1)

        mk("Frame",{
            Size=UDim2.fromOffset(3,999),
            BackgroundColor3=C.Accent,
            BorderSizePixel=0,ZIndex=52,Parent=n,
        })
        local inner=mk("Frame",{
            Size=UDim2.new(1,-14,1,0),
            Position=UDim2.fromOffset(14,0),
            BackgroundTransparency=1,ZIndex=52,Parent=n,
        }); pdg(inner,8,8,8,4)
        mk("TextLabel",{
            Size=UDim2.new(1,0,0,18),
            BackgroundTransparency=1,
            Text=cfg.Title or "Notice",
            TextColor3=C.Text,Font=Enum.Font.GothamBold,TextSize=13,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=53,Parent=inner,
        })
        mk("TextLabel",{
            Size=UDim2.new(1,0,0,14),
            Position=UDim2.fromOffset(0,20),
            BackgroundTransparency=1,
            Text=cfg.Message or "",
            TextColor3=C.TextSub,Font=Enum.Font.Gotham,TextSize=11,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=53,Parent=inner,
        })
        tw(n,{Size=UDim2.new(1,0,0,56)},0.2)
        task.delay(dur,function()
            tw(n,{Size=UDim2.new(1,0,0,0)},0.18)
            task.delay(0.2,function() n:Destroy() end)
        end)
    end

    -- Toggle key
    UserInputService.InputBegan:Connect(function(inp,gp)
        if gp then return end
        if inp.KeyCode==TOGKEY then main.Visible=not main.Visible end
    end)

    return Win
end

return NoraLib
