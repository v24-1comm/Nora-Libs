    -- ── Win:Tab(name) ──
    function Win:Tab(name)
        local isFirst = #self._tabs == 0

        -- Tab button
        local btn = makeInst("TextButton", {
            AutomaticSize    = Enum.AutomaticSize.X,
            Size             = UDim2.new(0, 0, 1, 0),
            BackgroundTransparency = 1,
            Text             = name,
            TextColor3       = isFirst and theme.Accent or theme.TextMuted,
            Font             = Enum.Font.GothamBold,
            TextSize         = 12,
            ZIndex           = 3,
            Parent           = tabBar,
        })
        padding(btn, 0, 12, 0, 12)

        -- Underline indicator
        local indicator = makeInst("Frame", {
            Size             = UDim2.new(1, 0, 0, 2),
            Position         = UDim2.new(0, 0, 1, -1),
            BackgroundColor3 = theme.Accent,
            BackgroundTransparency = isFirst and 0 or 1,
            BorderSizePixel  = 0,
            ZIndex           = 4,
            Parent           = btn,
        })

        -- Scroll frame (content page)
        local page = makeInst("ScrollingFrame", {
            Size             = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.Surface3,
            CanvasSize       = UDim2.new(1, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible          = isFirst,
            Parent           = contentHost,
        })
        padding(page, 10, 10, 10, 10)

        local pageLayout = listLayout(page, nil, 6)

        local Tab = { _page = page, _theme = theme, _layout = pageLayout }

        -- Activate this tab
        local function activate()
            for _, t in ipairs(Win._tabs) do
                t._page.Visible = false
                tween(t._btn, { TextColor3 = theme.TextMuted }, 0.15)
                tween(t._ind, { BackgroundTransparency = 1 }, 0.15)
            end
            page.Visible = true
            tween(btn,       { TextColor3 = theme.Accent }, 0.15)
            tween(indicator, { BackgroundTransparency = 0 }, 0.15)
            Win._activeTab = Tab
        end

        Tab._btn = btn
        Tab._ind = indicator
        btn.Activated:Connect(activate)
        if isFirst then Win._activeTab = Tab end

        table.insert(Win._tabs, Tab)

