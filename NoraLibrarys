-------------------------------------------------
-- TWEEN
-------------------------------------------------
local function tw(obj, props, t)
    TweenService:Create(obj, TweenInfo.new(t or 0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

-------------------------------------------------
-- THEME
-------------------------------------------------
local C = {
    BG          = Color3.fromRGB(10,  11,  17),
    Sidebar     = Color3.fromRGB(15,  16,  24),
    Panel       = Color3.fromRGB(19,  20,  30),
    Card        = Color3.fromRGB(25,  27,  40),
    CardHov     = Color3.fromRGB(31,  33,  50),
    CardSel     = Color3.fromRGB(37,  39,  60),
    Accent      = Color3.fromRGB(112, 100, 255),
    AccentHi    = Color3.fromRGB(140, 130, 255),
    Red         = Color3.fromRGB(255,  85,  85),
    Text        = Color3.fromRGB(225, 227, 238),
    TextSub     = Color3.fromRGB(155, 158, 180),
    TextMut     = Color3.fromRGB(85,   88, 112),
    Border      = Color3.fromRGB(34,  32,  65),
    BorderLt    = Color3.fromRGB(50,  48,  88),
}

-------------------------------------------------
-- HELPERS
-------------------------------------------------
local function mk(cls, t)
    local o = Instance.new(cls)
    for k,v in pairs(t) do o[k]=v end
    return o
end

local function rnd(p, r)
    local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r or 7); c.Parent=p
end

local function bdr(p, col, th)
    local s=Instance.new("UIStroke")
    s.Color=col or C.Border; s.Thickness=th or 1
    s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border; s.Parent=p
end

local function pdg(p, top, right, bot, left)
    local u=Instance.new("UIPadding")
    u.PaddingTop=UDim.new(0,top or 0); u.PaddingRight=UDim.new(0,right or 0)
    u.PaddingBottom=UDim.new(0,bot or 0); u.PaddingLeft=UDim.new(0,left or 0)
    u.Parent=p
end

-- Vertical list layout (returns layout object)
local function vlay(p, gap)
    local l=Instance.new("UIListLayout")
    l.FillDirection=Enum.FillDirection.Vertical
    l.HorizontalAlignment=Enum.HorizontalAlignment.Left
    l.SortOrder=Enum.SortOrder.LayoutOrder
    l.Padding=UDim.new(0, gap or 6)
    l.Parent=p; return l
end

-------------------------------------------------
-- DRAG
-------------------------------------------------
local function drag(handle, frame)
    local on, s0, p0
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            on=true; s0=i.Position; p0=frame.Position
            i.Changed:Connect(function()
                if i.UserInputState==Enum.UserInputState.End then on=false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if on and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-s0
            frame.Position=UDim2.new(p0.X.Scale,p0.X.Offset+d.X,p0.Y.Scale,p0.Y.Offset+d.Y)
        end
    end)
end

